# LLM Configuration for Quantum Assistant
# Copy this file to .env and fill in your API keys

# Choose your LLM provider: "gemini", "groq", or "ollama"
LLM_PROVIDER=gemini

# Google Gemini API Key
# Get your free API key from: https://makersuite.google.com/app/apikey
# or https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (optional, for faster responses)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Note: For Ollama (local LLM), no API key needed
# Just make sure Ollama is running: ollama serve
